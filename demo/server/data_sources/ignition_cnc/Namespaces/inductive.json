{
    "$schema": "http://json-schema.org/draft-04/schema#",
    "$id": "http://inductiveautomation.com/UDT/v1.0",
    "types": {
        "Motor": {
            "description": "Inductive Automation UDT for a simple motor with monitoring properties",
            "type": "object",
            "parameters": {
                "NamespaceUri": "http://inductiveautomation.com/UDT/",
                "UAPrefix": null,
                "UAServer": null
            },
            "properties": {
                "Amps": {
                    "type": "string",
                    "description": "Motor current draw in amperes"
                },
                "HOA": {
                    "type": "string",
                    "enum": ["Hand", "Off", "Auto"],
                    "description": "Hand-Off-Auto switch position"
                },
                "Running": {
                    "type": "string",
                    "description": "Whether the motor is currently running"
                },
                "Fault": {
                    "type": "string",
                    "description": "Motor fault indicator"
                }
            }
        }
    }
}
